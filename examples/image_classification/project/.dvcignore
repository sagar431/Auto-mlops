# DVC ignore file - files matching patterns will be excluded from DVC tracking

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/

# IDE files
.idea/
.vscode/
*.swp
*.swo

# Hydra outputs
outputs/
.hydra/

# Jupyter notebooks
.ipynb_checkpoints/

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.coverage
htmlcov/
