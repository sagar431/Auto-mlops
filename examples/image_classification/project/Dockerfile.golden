FROM python:3.10.18-slim-bookworm@sha256:445b9efb2c047a7ccdb30d293fd6b1aa0f62a55062dc2b69051df91e10848749

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    GOLDEN_MODEL_PATH=/models/model.pt

WORKDIR /app

COPY requirements.golden.txt ./
RUN python -m pip install --no-cache-dir --requirement requirements.golden.txt

RUN useradd --create-home --uid 10001 appuser
COPY --chown=appuser:appuser model.py inference.py golden_train.py serve.py ./

USER appuser
EXPOSE 8000
HEALTHCHECK --interval=2s --timeout=2s --start-period=5s --retries=10 \
    CMD ["python", "-c", "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/health', timeout=1)"]

CMD ["uvicorn", "serve:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]
