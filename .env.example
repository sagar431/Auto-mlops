# Updated .env.example for MLOps Agent

# LLM Provider API Keys
OPENAI_API_KEY=your_openai_key_here
GOOGLE_API_KEY=your_google_gemini_key_here

# Default LLM Model (options: gemini, gpt4, gpt35)
DEFAULT_MODEL=gemini

# MLflow Configuration
MLFLOW_TRACKING_URI=mlruns
MLFLOW_EXPERIMENT_NAME=default

# DVC Remote Storage (S3)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
DVC_REMOTE_URL=s3://your-bucket/dvc-storage

# Docker Registry (for pushing images)
DOCKER_REGISTRY=ghcr.io
DOCKER_USERNAME=your_username
DOCKER_PASSWORD=your_token

# GitHub (for triggering workflows)
GITHUB_TOKEN=your_github_token
GITHUB_OWNER=your_username
GITHUB_REPO=your_repo

# Agent Settings
MAX_IMPROVEMENT_ATTEMPTS=3
DEFAULT_ACCURACY_THRESHOLD=0.85
