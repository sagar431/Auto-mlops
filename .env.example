# Updated .env.example for MLOps Agent

# LLM Provider API Keys
OPENAI_API_KEY=your_openai_key_here
GOOGLE_API_KEY=your_google_gemini_key_here

# Default LLM Model (options: gemini, gpt4, gpt35)
DEFAULT_MODEL=gemini

# MLflow Configuration
MLFLOW_TRACKING_URI=mlruns
MLFLOW_EXPERIMENT_NAME=default

# DVC Remote Storage (S3)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
DVC_REMOTE_URL=s3://your-bucket/dvc-storage

# Docker Registry (for pushing images)
DOCKER_REGISTRY=ghcr.io
DOCKER_USERNAME=your_username
DOCKER_PASSWORD=your_token

# GitHub (for triggering workflows)
GITHUB_TOKEN=your_github_token
GITHUB_OWNER=your_username
GITHUB_REPO=your_repo

# Agent Settings
MAX_IMPROVEMENT_ATTEMPTS=3
DEFAULT_ACCURACY_THRESHOLD=0.85

# Database Configuration
# SQLite (default for development): sqlite:///./mlops_agent.db
# PostgreSQL (production): postgresql://user:password@localhost:5432/mlops_agent
DATABASE_URL=sqlite:///./mlops_agent.db

# API Server Settings
# Comma-separated list of allowed CORS origins (e.g., "http://localhost:3000,https://example.com")
# If not set, defaults to "*" (all origins allowed)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_REQUESTS=100  # requests per minute per API key

# Deployment: Hugging Face (for Gradio Spaces deployment)
HF_TOKEN=your_huggingface_token

# Deployment: AWS Lambda/CDK
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1

# Observability
LOG_LEVEL=INFO
LOG_FORMAT=json  # json or text

# HashiCorp Vault (optional, for secrets management)
# VAULT_ADDR=https://vault.example.com
# VAULT_TOKEN=hvs.xxxxx

# Redis (optional, for rate limiting with multiple workers)
# REDIS_URL=redis://localhost:6379/0
